  echo -e "\033[38;5;51m    ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó\033[38;5;199m‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó\033[38;5;46m‚Ėą‚Ėą‚Ėą‚ēó   ‚Ėą‚Ėą‚ēó"
  echo -e "\033[38;5;51m    ‚ēö‚ēź‚ēź‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ\033[38;5;199m‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ\033[38;5;46m‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚ēĎ"
  echo -e "\033[38;5;51m      ‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ \033[38;5;199m‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  \033[38;5;46m‚Ėą‚Ėą‚ēĒ‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēĎ"
  echo -e "\033[38;5;51m     ‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ  \033[38;5;199m‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēĚ  \033[38;5;46m‚Ėą‚Ėą‚ēĎ‚ēö‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ"
  echo -e "\033[38;5;51m    ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó\033[38;5;199m‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó\033[38;5;46m‚Ėą‚Ėą‚ēĎ ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ"
  echo -e "\033[38;5;51m    ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ\033[38;5;199m‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ\033[38;5;46m‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēź‚ēź‚ēĚ"
  echo -e "\033[38;5;245m       NHK26 Edition${NC}"
