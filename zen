#!/bin/bash
# =============================================================
# zen - NHK26 CTF CLI
# Usage: ./zen <command>
# =============================================================

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
NC='\033[0m'

